generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String?  
  googleId  String?  @unique
  createdAt DateTime @default(now())
}

model Character {
  id       Int      @id @default(autoincrement())
  name     String
  gender   String
  culture  String
  born     String
  died     String
  titles   String[]
  aliases  String[]
}